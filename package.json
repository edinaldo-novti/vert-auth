{
  "name": "@vert/auth",
  "version": "0.1.0",
  "type": "module",
  "description": "Authentication library for Bun: password hashing (Argon2id), sessions, confirmable, recoverable, lockable, trackable, and OmniAuth-like providers.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./authenticatable": {
      "import": "./dist/authenticatable/index.js",
      "types": "./dist/authenticatable/index.d.ts"
    },
    "./confirmable": {
      "import": "./dist/confirmable/index.js",
      "types": "./dist/confirmable/index.d.ts"
    },
    "./recoverable": {
      "import": "./dist/recoverable/index.js",
      "types": "./dist/recoverable/index.d.ts"
    },
    "./lockable": {
      "import": "./dist/lockable/index.js",
      "types": "./dist/lockable/index.d.ts"
    },
    "./omniauth": {
      "import": "./dist/omniauth/index.js",
      "types": "./dist/omniauth/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target bun && bun run build:types",
    "build:types": "tsc --emitDeclarationOnly --outDir dist",
    "test": "bun test",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "bun run clean && bun run build && bun run test"
  },
  "keywords": [
    "bun",
    "vert",
    "authentication",
    "argon2",
    "devise",
    "password",
    "sessions",
    "oauth"
  ],
  "author": "Vert Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/edinaldo-at/vert-auth.git"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "dependencies": {
    "@vert/core": "^0.1.0",
    "zod": "^3.23.0"
  },
  "peerDependencies": {
    "drizzle-orm": ">=0.30.0"
  },
  "peerDependenciesMeta": {
    "drizzle-orm": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.5.0",
    "drizzle-orm": ">=0.30.0"
  }
}
